{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "permissions": {
    "ask": [
      "Edit(**/Cargo.toml)",
      "Edit(**/Cargo.lock)",
      "Edit(**/rust-toolchain.toml)",
      "Edit(**/package.json)",
      "Edit(**/package-lock.json)",
      "Edit(**/pnpm-lock.yaml)",
      "Edit(**/pnpm-workspace.yaml)",
      "Edit(**/tsconfig*.json)",
      "Edit(**/jsconfig.json)",
      "Edit(**/*.config.js)",
      "Edit(**/*.config.ts)",
      "Edit(**/*.config.mjs)",
      "Edit(**/*.config.cjs)",
      "Edit(**/*.config.mts)",
      "Edit(**/.eslintrc*)",
      "Edit(**/.babelrc*)",
      "Edit(**/.npmrc)",
      "Edit(**/bun.lock*)",
      "Edit(**/pyproject.toml)",
      "Edit(**/requirements*.txt)",
      "Edit(**/setup.py)",
      "Edit(**/setup.cfg)",
      "Edit(**/uv.lock)",
      "Edit(**/poetry.lock)",
      "Edit(**/Pipfile*)",
      "Edit(**/go.mod)",
      "Edit(**/go.sum)",
      "Edit(**/go.work)",
      "Edit(**/Gemfile*)",
      "Edit(**/pom.xml)",
      "Edit(**/build.gradle*)",
      "Edit(**/pixi.toml)",
      "Edit(**/pixi.lock)",
      "Edit(**/.github/workflows/**)",
      "Edit(**/.github/dependabot.yml)",
      "Edit(**/Dockerfile*)",
      "Edit(**/docker-compose*.y*ml)",
      "Edit(**/Makefile)",
      "Edit(**/GNUmakefile)",
      "Edit(**/justfile)",
      "Edit(**/Justfile)",
      "Edit(**/CMakeLists.txt)",
      "Edit(**/*.tf)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Bash(sed -i:*)",
      "Bash(sed -ri:*)",
      "Bash(sed -Ei:*)",
      "Bash(sed -ni:*)",
      "Bash(sed --in-place:*)"
    ]
  }
}
