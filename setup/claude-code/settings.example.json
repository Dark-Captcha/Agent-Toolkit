{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "permissions": {
    "ask": [
      "Edit(**/Cargo.toml)",
      "Write(**/Cargo.toml)",
      "Edit(**/Cargo.lock)",
      "Write(**/Cargo.lock)",
      "Edit(**/package.json)",
      "Write(**/package.json)",
      "Edit(**/package-lock.json)",
      "Write(**/package-lock.json)",
      "Edit(**/tsconfig*.json)",
      "Write(**/tsconfig*.json)",
      "Edit(**/jsconfig.json)",
      "Write(**/jsconfig.json)",
      "Edit(**/*.config.js)",
      "Write(**/*.config.js)",
      "Edit(**/*.config.ts)",
      "Write(**/*.config.ts)",
      "Edit(**/*.config.mjs)",
      "Write(**/*.config.mjs)",
      "Edit(**/*.config.cjs)",
      "Write(**/*.config.cjs)",
      "Edit(**/*.config.mts)",
      "Write(**/*.config.mts)",
      "Edit(**/.eslintrc*)",
      "Write(**/.eslintrc*)",
      "Edit(**/.babelrc*)",
      "Write(**/.babelrc*)",
      "Edit(**/.npmrc)",
      "Write(**/.npmrc)",
      "Edit(**/bun.lock*)",
      "Write(**/bun.lock*)",
      "Edit(**/pyproject.toml)",
      "Write(**/pyproject.toml)",
      "Edit(**/requirements*.txt)",
      "Write(**/requirements*.txt)",
      "Edit(**/setup.py)",
      "Write(**/setup.py)",
      "Edit(**/setup.cfg)",
      "Write(**/setup.cfg)",
      "Edit(**/uv.lock)",
      "Write(**/uv.lock)",
      "Edit(**/poetry.lock)",
      "Write(**/poetry.lock)",
      "Edit(**/Pipfile*)",
      "Write(**/Pipfile*)",
      "Edit(**/go.mod)",
      "Write(**/go.mod)",
      "Edit(**/go.sum)",
      "Write(**/go.sum)",
      "Edit(**/Gemfile*)",
      "Write(**/Gemfile*)",
      "Edit(**/pom.xml)",
      "Write(**/pom.xml)",
      "Edit(**/build.gradle*)",
      "Write(**/build.gradle*)",
      "Edit(**/pixi.toml)",
      "Write(**/pixi.toml)",
      "Edit(**/pixi.lock)",
      "Write(**/pixi.lock)",
      "Edit(**/.github/workflows/**)",
      "Write(**/.github/workflows/**)",
      "Edit(**/Dockerfile*)",
      "Write(**/Dockerfile*)",
      "Edit(**/docker-compose*.y*ml)",
      "Write(**/docker-compose*.y*ml)",
      "Edit(**/Makefile)",
      "Write(**/Makefile)",
      "Edit(**/justfile)",
      "Write(**/justfile)",
      "Edit(**/CMakeLists.txt)",
      "Write(**/CMakeLists.txt)",
      "Edit(**/*.tf)",
      "Write(**/*.tf)",
      "Edit(**/.env)",
      "Write(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env.*)",
      "Bash(sed -i:*)",
      "Bash(sed --in-place:*)"
    ]
  }
}
